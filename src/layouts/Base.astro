---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  publishedTime?: string;
  noindex?: boolean;
  jsonld?: Record<string, unknown>[];
}

const {
  title = 'Ivan Garcia — Desarrollador Web',
  description = 'Ivan Garcia, desarrollador web en Mérida. Construyo tiendas Shopify y aplicaciones web a la medida que ayudan a las marcas a crecer.',
  image = 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1200&h=630&q=80',
  ogType = 'website',
  publishedTime,
  noindex = false,
  jsonld = [],
} = Astro.props;

const site = Astro.site ?? new URL(Astro.url.origin);
const origin = site.origin;
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;

const baseGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${origin}/#website`,
      url: `${origin}/`,
      name: 'Ivan Garcia',
      description:
        'Desarrollador web en Mérida. Construyo tiendas Shopify y aplicaciones web a la medida que ayudan a las marcas a crecer.',
      inLanguage: 'es-MX',
      publisher: { '@id': `${origin}/#person` },
    },
    {
      '@type': 'Person',
      '@id': `${origin}/#person`,
      name: 'Ivan Garcia',
      givenName: 'Ivan',
      familyName: 'Garcia',
      jobTitle: 'Desarrollador Web',
      description:
        'Diseño y construyo tiendas Shopify y aplicaciones web a la medida que ayudan a las marcas a crecer.',
      url: `${origin}/about/`,
      image:
        'https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e0dc2fa47b997376625a9_581242616_2615477665490146_3560785756473390153_n.jpg',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Mérida',
        addressRegion: 'Yucatán',
        addressCountry: 'MX',
      },
      telephone: '+52-999-128-4580',
      knowsAbout: [
        'Shopify', 'Desarrollo web', 'Liquid', 'React', 'Node.js',
        'Aplicaciones móviles', 'Diseño UI/UX', 'Ecommerce', 'Figma', 'Astro',
      ],
      sameAs: [
        'https://www.instagram.com/ivangarcia10/',
        'https://www.linkedin.com/in/ivanalexisgarcia/',
      ],
      worksFor: { '@id': `${origin}/#organization` },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${origin}/#organization`,
      name: 'Ivan Garcia — Desarrollador Web',
      alternateName: 'ivang.mx',
      description:
        'Diseño y desarrollo de tiendas Shopify y aplicaciones web a la medida en Mérida, México.',
      url: `${origin}/`,
      logo: { '@type': 'ImageObject', url: `${origin}/favicon.svg` },
      founder: { '@id': `${origin}/#person` },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Mérida',
        addressRegion: 'Yucatán',
        addressCountry: 'MX',
      },
      telephone: '+52-999-128-4580',
      areaServed: [{ '@type': 'Country', name: 'México' }],
      sameAs: [
        'https://www.instagram.com/ivangarcia10/',
        'https://www.linkedin.com/in/ivanalexisgarcia/',
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Servicios de desarrollo web',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', '@id': `${origin}/services/web-design/#service`, name: 'Diseño web a la medida' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', '@id': `${origin}/services/ecommerce-shopify/#service`, name: 'Ecommerce con Shopify' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', '@id': `${origin}/services/mobile-apps/#service`, name: 'Mobile Apps' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', '@id': `${origin}/services/web-apps/#service`, name: 'Web Apps' } },
        ],
      },
    },
  ],
};
const graphs = [baseGraph, ...jsonld];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <!-- Inbound page-transition: if we arrived via an internal link, pre-cover the
       screen before first paint, then lift the curtain to reveal. Runs early and
       self-contained (no dependency on app.js); a hard timeout guarantees the
       page is never left covered, even if animations are throttled. -->
  <script is:inline>
    (function () {
      try {
        // Enable the reveal entrance only when JS is confirmed, before first
        // paint. Without this class, .reveal content stays visible by default.
        document.documentElement.classList.add('js-anim');
      } catch (e) {}
      try {
        if (sessionStorage.getItem('pt-go') !== '1') return;
        sessionStorage.removeItem('pt-go');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var html = document.documentElement;
        html.classList.add('pt-incoming');
        var cleared = false;
        function clear() {
          if (cleared) return; cleared = true;
          html.classList.remove('pt-incoming');
          var ov = document.querySelector('.page-trans');
          if (ov) ov.classList.remove('revealing');
        }
        function reveal() {
          var ov = document.querySelector('.page-trans');
          if (!ov) { clear(); return; }
          ov.classList.add('revealing');
          ov.addEventListener('animationend', clear, { once: true });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', reveal, { once: true });
        } else { reveal(); }
        setTimeout(clear, 2400); // safety ceiling — never leave the page covered
      } catch (e) {}
    })();
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="theme-color" content="#090909" />

  <!-- Open Graph / social -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Ivan Garcia" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:image" content={ogImage} />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {publishedTime && <meta property="article:author" content={`${origin}/about/`} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://images.unsplash.com" />
  <link rel="preconnect" href="https://cdn.prod.website-files.com" />
  <link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- No-JS / crawler fallback: reveal-gated content must be visible without the
       IntersectionObserver, otherwise everything below the hero ships blank. -->
  <noscript><style>
    .reveal { opacity: 1 !important; transform: none !important; }
    .line-inner, .word > span { transform: none !important; }
  </style></noscript>
  {graphs.map((g) => <script type="application/ld+json" set:html={JSON.stringify(g)} />)}
</head>
<body>

  <a class="skip-link" href="#main">Saltar al contenido</a>

  <!-- PAGE TRANSITION -->
  <div class="page-trans" aria-hidden="true"><div class="page-trans__label"></div></div>

  <Nav />
  <MobileMenu />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <!-- floating project preview -->
  <div class="project__peek"><img alt="" /></div>

  <script is:inline src="https://unpkg.com/lucide@0.288.0/dist/umd/lucide.js"></script>
  <script is:inline src="/app.js"></script>
</body>
</html>
