---
import Base from '../layouts/Base.astro';
---

<Base
  title="Servicios — Ivan Garcia"
  description="Del diseño al despliegue: web design, ecommerce Shopify, mobile apps y web apps. Soluciones digitales escalables, rápidas y pensadas para tu negocio."
>
  <!-- HERO -->
  <section class="hero wrap" style="min-height:64svh;">
    <div class="hero__inner">
      <p class="eyebrow">Servicios</p>
      <h1 class="display d-xxl" data-hero-split style="margin-top:22px;max-width:13ch;">Lo que necesitas para lanzar y crecer.</h1>
      <p class="lead muted reveal" data-d="3" style="margin-top:26px;max-width:48ch;">Del diseño al despliegue: soluciones digitales escalables, rápidas y pensadas para tu negocio.</p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="wrap section--tight">
    <div class="rows reveal">
      <div class="row">
        <div class="row__num">01</div>
        <div class="row__body">
          <div class="row__head"><h3 class="row__title">Web Design</h3><span class="row__icon"><i data-lucide="layout"></i></span></div>
          <p class="row__desc">Interfaces modernas, rápidas y a la medida de tu marca. Diseño centrado en el usuario que comunica con claridad y convierte.</p>
          <div class="row__tags"><span class="chip">UI / UX</span><span class="chip">Responsive</span><span class="chip">Branding</span></div>
        </div>
      </div>
      <div class="row">
        <div class="row__num">02</div>
        <div class="row__body">
          <div class="row__head"><h3 class="row__title">Ecommerce — Shopify</h3><span class="row__icon"><i data-lucide="shopping-bag"></i></span></div>
          <p class="row__desc">Tiendas que venden: temas custom, integraciones a la medida y optimización de conversión y rendimiento.</p>
          <div class="row__tags"><span class="chip">Shopify</span><span class="chip">Liquid</span><span class="chip">CRO</span></div>
        </div>
      </div>
      <div class="row">
        <div class="row__num">03</div>
        <div class="row__body">
          <div class="row__head"><h3 class="row__title">Mobile Apps</h3><span class="row__icon"><i data-lucide="smartphone"></i></span></div>
          <p class="row__desc">Aplicaciones móviles con foco en experiencia y rendimiento, listas para escalar con tu producto.</p>
          <div class="row__tags"><span class="chip">iOS / Android</span><span class="chip">UX</span><span class="chip">Performance</span></div>
        </div>
      </div>
      <div class="row">
        <div class="row__num">04</div>
        <div class="row__body">
          <div class="row__head"><h3 class="row__title">Web Apps</h3><span class="row__icon"><i data-lucide="layers"></i></span></div>
          <p class="row__desc">Plataformas escalables construidas con código limpio, arquitectura sólida e integraciones robustas.</p>
          <div class="row__tags"><span class="chip">React</span><span class="chip">APIs</span><span class="chip">Escalable</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW -->
  <section class="section wrap">
    <div class="split">
      <div class="stack-md">
        <p class="eyebrow reveal">Cómo trabajo</p>
        <h2 class="display d-lg reveal" data-d="1">Un proceso claro, de la idea al lanzamiento.</h2>
        <p class="lead muted reveal" data-d="2" style="max-width:46ch;">Descubrir, definir, desarrollar y entregar — con comunicación constante y foco en resultados medibles.</p>
        <div class="reveal" data-d="3"><a class="btn btn--secondary" href="/about" data-label="Sobre mí">Ver mi proceso <span class="arrow">↗</span></a></div>
      </div>
      <div class="spotlight spotlight--violet reveal" data-d="1" style="min-height:320px;display:flex;flex-direction:column;justify-content:flex-end;">
        <p class="display d-md" style="color:#fff;">Código limpio. Rendimiento real. Diseño que convierte.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section wrap">
    <div class="spotlight reveal" style="text-align:center;padding-block:clamp(56px,10vw,110px);">
      <h2 class="display d-xl" style="color:#fff;margin:0 auto;max-width:16ch;">Cuéntame qué quieres construir.</h2>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:30px;">
        <a class="btn btn--primary" href="/contact" data-label="Hablemos" data-magnetic="0.3">Hablemos <span class="arrow">↗</span></a>
        <a class="btn btn--secondary" href="https://wa.me/529991284580" target="_blank" rel="noopener" style="background:rgba(255,255,255,0.16);">WhatsApp</a>
      </div>
    </div>
  </section>
</Base>
