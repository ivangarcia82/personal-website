---
import Base from '../../layouts/Base.astro';
const U = (id: string, w = 1400) => `https://images.unsplash.com/${id}?auto=format&fit=crop&w=${w}&q=70`;
---

<Base
  title="Web Apps — Servicios · Ivan Garcia"
  description="Plataformas y aplicaciones web a la medida: arquitectura escalable, integraciones robustas, paneles de control y código limpio que crece con tu negocio."
  jsonld={[
    {
      '@type': 'Service',
      '@id': 'https://www.ivang.mx/services/web-apps/#service',
      name: 'Web Apps',
      url: 'https://www.ivang.mx/services/web-apps/',
      description: 'Plataformas y aplicaciones web a la medida: arquitectura escalable, integraciones robustas, paneles de control y código limpio que crece con tu negocio.',
      serviceType: 'Desarrollo de aplicaciones web',
      inLanguage: 'es-MX',
      provider: { '@id': 'https://www.ivang.mx/#organization' },
      areaServed: { '@type': 'Country', name: 'México' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.ivang.mx/' },
        { '@type': 'ListItem', position: 2, name: 'Servicios', item: 'https://www.ivang.mx/services/' },
        { '@type': 'ListItem', position: 3, name: 'Web Apps' },
      ],
    },
  ]}
>
  <!-- HEADER -->
  <section class="wrap" style="padding-top:118px;padding-bottom:clamp(28px,5vw,52px);">
    <a class="case-back" href="/services" data-label="Servicios"><span class="arrow">←</span> Volver a Servicios</a>
    <p class="eyebrow" style="display:flex;margin-top:26px;">Servicio · Web Apps</p>
    <h1 class="display d-xl" data-hero-split style="margin-top:18px;max-width:14ch;">Plataformas web a la medida</h1>
    <p class="lead muted reveal" data-d="2" style="margin-top:24px;max-width:54ch;">Cuando una página no alcanza: aplicaciones web con lógica propia, paneles de control e integraciones, construidas sobre una arquitectura que aguanta el crecimiento.</p>
  </section>

  <!-- LEAD VISUAL -->
  <section class="wrap">
    <div class="media reveal" data-parallax="0.05" style="aspect-ratio:16/8;border-radius:var(--r-xxl);">
      <img src={U('photo-1551288049-bebda4e38f71', 1600)} alt="Panel de control con gráficas de datos en pantalla" />
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section wrap">
    <div class="split" style="align-items:start;">
      <div class="stack-md">
        <p class="eyebrow reveal">Qué incluye</p>
        <h2 class="display d-lg reveal" data-d="1" style="max-width:14ch;">Software que resuelve tu operación.</h2>
        <p class="lead muted reveal" data-d="2" style="max-width:42ch;">Hecho alrededor de cómo funciona tu negocio, no al revés.</p>
      </div>
      <ul class="checklist reveal" data-d="1">
        <li><i data-lucide="layers"></i><div><span class="ck-t">Arquitectura escalable</span><span class="ck-d">Una base que soporta más usuarios y más datos sin reescribirse.</span></div></li>
        <li><i data-lucide="plug"></i><div><span class="ck-t">Integraciones</span><span class="ck-d">Conexión con APIs, pasarelas y los sistemas que ya usa tu equipo.</span></div></li>
        <li><i data-lucide="layout-dashboard"></i><div><span class="ck-t">Paneles y dashboards</span><span class="ck-d">Vistas claras para administrar y entender lo que pasa en tu operación.</span></div></li>
        <li><i data-lucide="lock"></i><div><span class="ck-t">Autenticación y roles</span><span class="ck-d">Acceso seguro y permisos según quién usa cada parte del sistema.</span></div></li>
        <li><i data-lucide="git-branch"></i><div><span class="ck-t">Código limpio y mantenible</span><span class="ck-d">Para que cualquier desarrollador pueda continuarlo sin pelear con él.</span></div></li>
      </ul>
    </div>
  </section>

  <!-- SECONDARY VISUAL -->
  <section class="wrap section--tight">
    <div class="grid-2 reveal">
      <div class="media ratio-4-3" data-parallax="0.06"><img src={U('photo-1517180102446-f3ece451e9d8', 1100)} width="1200" height="900" alt="Código de una aplicación web en un editor" /></div>
      <div class="media ratio-4-3" data-parallax="0.1"><img src={U('photo-1460925895917-afdab827c52f', 1100)} width="1200" height="900" alt="Gráficas de analítica en una pantalla" /></div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section wrap">
    <p class="eyebrow reveal">Cómo trabajo</p>
    <h2 class="display d-lg reveal" data-d="1" style="margin-top:14px;max-width:16ch;">De requisitos a plataforma en producción.</h2>
    <div class="rows reveal" data-d="1" style="margin-top:34px;">
      <div class="row"><div class="row__num">01</div><div class="row__body"><div class="row__head"><h3 class="row__title">Entender la operación</h3></div><p class="row__desc">Mapeo el problema real y los flujos que el sistema tiene que soportar.</p></div></div>
      <div class="row"><div class="row__num">02</div><div class="row__body"><div class="row__head"><h3 class="row__title">Diseñar la arquitectura</h3></div><p class="row__desc">Defino estructura de datos, integraciones y la estrategia técnica.</p></div></div>
      <div class="row"><div class="row__num">03</div><div class="row__body"><div class="row__head"><h3 class="row__title">Desarrollar por etapas</h3></div><p class="row__desc">Construyo en entregas revisables para ver avances reales pronto.</p></div></div>
      <div class="row"><div class="row__num">04</div><div class="row__body"><div class="row__head"><h3 class="row__title">Desplegar y dar seguimiento</h3></div><p class="row__desc">Lanzo a producción, monitoreo y optimizo con base en el uso real.</p></div></div>
    </div>
  </section>

  <!-- DELIVERABLES -->
  <section class="wrap section--tight">
    <div class="split" style="align-items:start;">
      <div class="stack-md">
        <p class="eyebrow reveal">Lo que recibes</p>
        <h2 class="display d-lg reveal" data-d="1" style="max-width:12ch;">Una plataforma tuya y mantenible.</h2>
      </div>
      <ul class="checklist reveal" data-d="1">
        <li><i data-lucide="server"></i><div><span class="ck-t">Aplicación desplegada y funcionando</span></div></li>
        <li><i data-lucide="code-2"></i><div><span class="ck-t">Código fuente documentado y tuyo</span></div></li>
        <li><i data-lucide="book-open"></i><div><span class="ck-t">Documentación técnica de la arquitectura</span></div></li>
        <li><i data-lucide="activity"></i><div><span class="ck-t">Monitoreo para detectar problemas a tiempo</span></div></li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section wrap">
    <p class="eyebrow reveal">Preguntas frecuentes</p>
    <div class="faq reveal" data-d="1" style="margin-top:24px;">
      <div class="faq__item"><h3 class="faq__q">¿En qué se diferencia de una página web?</h3><p class="faq__a">Una página presenta información; una web app hace cosas: gestiona usuarios, datos, procesos y lógica de negocio. Si tu equipo necesita operar dentro del sistema, es una web app.</p></div>
      <div class="faq__item"><h3 class="faq__q">¿Se integra con lo que ya uso?</h3><p class="faq__a">Esa suele ser la razón de construirla a la medida. Conecto la plataforma con tus sistemas actuales mediante APIs en lugar de obligarte a cambiar de herramientas.</p></div>
      <div class="faq__item"><h3 class="faq__q">¿Cómo evitas que se vuelva inmantenible?</h3><p class="faq__a">Con una arquitectura clara, código documentado y entregas por etapas. El objetivo es que cualquier desarrollador pueda continuar el proyecto sin partir de cero.</p></div>
      <div class="faq__item"><h3 class="faq__q">¿Puedes retomar un proyecto existente?</h3><p class="faq__a">Sí. Reviso el estado del código, te doy un diagnóstico honesto y trabajamos sobre lo que vale la pena conservar.</p></div>
    </div>
  </section>

  <!-- OTHER SERVICES -->
  <section class="wrap section--tight">
    <p class="eyebrow reveal">Otros servicios</p>
    <div class="contact-list reveal" data-d="1" style="margin-top:18px;">
      <a class="contact-item" href="/services/web-design" data-label="Web Design"><span class="ci-value">Web Design</span><span class="arrow">↗</span></a>
      <a class="contact-item" href="/services/ecommerce-shopify" data-label="Ecommerce — Shopify"><span class="ci-value">Ecommerce — Shopify</span><span class="arrow">↗</span></a>
      <a class="contact-item" href="/services/mobile-apps" data-label="Mobile Apps"><span class="ci-value">Mobile Apps</span><span class="arrow">↗</span></a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section wrap">
    <div class="spotlight reveal" style="text-align:center;padding-block:clamp(56px,10vw,110px);">
      <h2 class="display d-xl" style="color:#fff;margin:0 auto;max-width:16ch;">¿Construimos tu plataforma?</h2>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:30px;">
        <a class="btn btn--primary" href="/contact" data-label="Hablemos" data-magnetic="0.3">Hablemos <span class="arrow">↗</span></a>
      </div>
    </div>
  </section>
</Base>
