---
import Base from '../layouts/Base.astro';
---

<Base
  title="Trabajo — Ivan Garcia"
  description="Portafolio de Ivan Garcia: tiendas Shopify y aplicaciones web a la medida. Cómo el código se traduce en resultados de negocio."
>
  <!-- HERO -->
  <section class="hero wrap" style="min-height:52svh;">
    <div class="hero__inner">
      <p class="eyebrow">Portafolio</p>
      <h1 class="display d-xxl" data-hero-split style="margin-top:22px;">Trabajo seleccionado</h1>
      <p class="lead muted reveal" data-d="3" style="margin-top:26px;max-width:44ch;">Seis proyectos: tiendas Shopify, programas de experimentación y landings que convierten. Cómo el código se traduce en una mejor experiencia y en resultados de negocio.</p>
    </div>
  </section>

  <!-- PROJECT LIST (signature: hover lift + cursor peek; rows open the case study) -->
  <section class="wrap section--tight">
    <div class="projects reveal">
      <a class="project" href="/work/sandra-weil" data-label="Sandra Weil" data-peek="https://www.sandraweil.com/cdn/shop/files/sw_AllStore_3f082b2e-89b5-44db-9599-7538f88de4ad.png?width=900">
        <div><span class="tag">01</span><h3 class="project__title">Sandra Weil</h3></div>
        <div class="project__meta"><span>Moda · Ecommerce · Shopify</span><span>2025</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="/work/sognare" data-label="Sognare" data-peek="https://sognare.com.mx/cdn/shop/files/SG_MAY26_BannerExtensionDesc_1600x610_TS.jpg?width=900">
        <div><span class="tag">02</span><h3 class="project__title">Sognare</h3></div>
        <div class="project__meta"><span>Ecommerce · Shopify · CRO</span><span>2025</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="/work/pure-over" data-label="Pure Over" data-peek="https://cdn.shopify.com/s/files/1/0482/9721/4111/files/pure-over-signature-brew-kit-all-glass-pour-over-front.png?width=900">
        <div><span class="tag">03</span><h3 class="project__title">Pure Over</h3></div>
        <div class="project__meta"><span>Ecommerce · Shopify</span><span>2025</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="/work/cemex-supply" data-label="CEMEX Supply" data-peek="https://www.cemexsupply.com/cdn/shop/files/Banner_Conoce_catalogo_llantas.jpg?width=900">
        <div><span class="tag">04</span><h3 class="project__title">CEMEX Supply</h3></div>
        <div class="project__meta"><span>Ecommerce · Web App</span><span>2025</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="/work/mi-tienda-socio" data-label="Mi Tienda Socio" data-peek="https://mitiendasocio.com.mx/cdn/shop/files/Banner_2026_GS.jpg?width=900">
        <div><span class="tag">05</span><h3 class="project__title">Mi Tienda Socio</h3></div>
        <div class="project__meta"><span>Ecommerce · Shopify</span><span>2025</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="/work/terrakan" data-label="Terrakan" data-peek="https://terrakan.mx/wp-content/themes/terrakan/assets/img/familia-terrakan.jpeg">
        <div><span class="tag">06</span><h3 class="project__title">Terrakan Residencial</h3></div>
        <div class="project__meta"><span>Inmobiliaria · WordPress</span><span>2026</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section wrap">
    <div class="spotlight spotlight--orange reveal" style="text-align:center;padding-block:clamp(56px,10vw,110px);">
      <h2 class="display d-xl" style="color:#fff;margin:0 auto;max-width:16ch;">¿El siguiente proyecto es el tuyo?</h2>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:30px;">
        <a class="btn btn--primary" href="/contact" data-label="Hablemos" data-magnetic="0.3">Hablemos <span class="arrow">↗</span></a>
      </div>
    </div>
  </section>
</Base>
