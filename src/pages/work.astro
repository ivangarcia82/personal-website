---
import Base from '../layouts/Base.astro';
---

<Base
  title="Trabajo — Ivan Garcia"
  description="Portafolio de Ivan Garcia: tiendas Shopify y aplicaciones web a la medida. Cómo el código se traduce en resultados de negocio."
>
  <!-- HERO -->
  <section class="hero wrap" style="min-height:62svh;">
    <div class="hero__inner">
      <p class="eyebrow">Portafolio</p>
      <h1 class="display d-xxl" data-hero-split style="margin-top:22px;">Trabajo seleccionado</h1>
      <p class="lead muted reveal" data-d="3" style="margin-top:26px;max-width:44ch;">Cómo el código se traduce en resultados de negocio y experiencias de usuario excepcionales.</p>
    </div>
  </section>

  <!-- PROJECT LIST -->
  <section class="wrap section--tight">
    <div class="projects reveal">
      <a class="project" href="#pure-over" data-no-trans data-peek="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e118740ff47f0aec7eefa_close-up-woman-hand-using-credit-card-shopping-onl-2024-11-27-01-27-14-utc%20(1).jpg">
        <div><span class="tag">01</span><h3 class="project__title">Pure Over</h3></div>
        <div class="project__meta"><span>Ecommerce · Shopify</span><span>—</span><span>2023</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
      <a class="project" href="#cemex-supply" data-no-trans data-peek="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e11308e976663f9f463f4_it-development-background-2025-03-10-02-02-29-utc%20(1).jpg">
        <div><span class="tag">02</span><h3 class="project__title">CEMEX Supply</h3></div>
        <div class="project__meta"><span>Ecommerce · Web App</span><span>—</span><span>2023</span><span class="project__view">Ver caso <span class="arrow">↗</span></span></div>
      </a>
    </div>
  </section>

  <!-- CASE 1 -->
  <section class="section wrap" id="pure-over">
    <div class="split">
      <div class="stack-md">
        <p class="eyebrow reveal">01 — Pure Over</p>
        <h2 class="display d-lg reveal" data-d="1">Pure Over</h2>
        <p class="lead muted reveal" data-d="2" style="max-width:46ch;">Tienda Shopify diseñada y construida a la medida: tema custom, experiencia de compra fluida y rendimiento optimizado para convertir.</p>
        <div class="row__tags reveal" data-d="3">
          <span class="chip">Shopify</span><span class="chip">Tema custom</span><span class="chip">Ecommerce</span><span class="chip">2023</span>
        </div>
      </div>
      <div class="media ratio-4-3 reveal" data-d="1" data-parallax="0.08">
        <img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e118740ff47f0aec7eefa_close-up-woman-hand-using-credit-card-shopping-onl-2024-11-27-01-27-14-utc%20(1).jpg" alt="Pure Over" />
      </div>
    </div>
    <div class="grid-2 reveal" data-d="1" style="margin-top:24px;">
      <div class="media ratio-4-3"><img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e11cda416a837b91db079_a-woman-doing-online-shopping-2024-11-26-18-54-53-utc%20(1).jpg" alt="" /></div>
      <div class="media ratio-4-3"><img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e12218fb19c79a3db5b14_designer-testing-new-image-generator-2025-07-09-08-06-55-utc%20(1).jpg" alt="" /></div>
    </div>
  </section>

  <!-- CASE 2 -->
  <section class="section wrap" id="cemex-supply">
    <div class="split">
      <div class="media ratio-4-3 reveal" data-d="1" data-parallax="0.08" style="order:2;">
        <img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e11308e976663f9f463f4_it-development-background-2025-03-10-02-02-29-utc%20(1).jpg" alt="CEMEX Supply" />
      </div>
      <div class="stack-md" style="order:1;">
        <p class="eyebrow reveal">02 — CEMEX Supply</p>
        <h2 class="display d-lg reveal" data-d="1">CEMEX Supply</h2>
        <p class="lead muted reveal" data-d="2" style="max-width:46ch;">Plataforma de ecommerce y aplicación web para gestión de suministro: arquitectura escalable, integraciones a medida y foco en la operación a gran escala.</p>
        <div class="row__tags reveal" data-d="3">
          <span class="chip">Web App</span><span class="chip">Ecommerce</span><span class="chip">Integraciones</span><span class="chip">2023</span>
        </div>
      </div>
    </div>
    <div class="grid-2 reveal" data-d="1" style="margin-top:24px;">
      <div class="media ratio-4-3"><img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e4786acf53d329c33a858_software-developer-6521720_640.jpg" alt="" /></div>
      <div class="media ratio-4-3"><img src="https://cdn.prod.website-files.com/691e0d7b787f525f582b1cc6/691e475d08bd1968b51447ab_code-1076533_640.jpg" alt="" /></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section wrap">
    <div class="spotlight spotlight--orange reveal" style="text-align:center;padding-block:clamp(56px,10vw,110px);">
      <h2 class="display d-xl" style="color:#fff;margin:0 auto;max-width:16ch;">¿El siguiente proyecto es el tuyo?</h2>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:30px;">
        <a class="btn btn--primary" href="/contact" data-label="Hablemos" data-magnetic="0.3">Hablemos <span class="arrow">↗</span></a>
      </div>
    </div>
  </section>
</Base>
